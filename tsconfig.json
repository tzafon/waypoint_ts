{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ES2022",
      "outDir": "dist",
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "strict": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true,
      "types": ["node"]
    },
    "include": ["src/**/*.ts"]
  }
  